PORT=4000
OPENROUTER_API_KEY=your_openrouter_api_key_here
ALLOWED_ORIGIN=https://your-app.vercel.app

# Gmail API — booking confirmation emails
# Setup: https://console.cloud.google.com → Enable Gmail API → OAuth2 credentials
# Get refresh token via: https://developers.google.com/oauthplayground
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token
GMAIL_FROM=your_email@gmail.com
